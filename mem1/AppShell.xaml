<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="mem1.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:mem1"
    Title="mem1">

    <TabBar>
        <Tab Title="Главная">
            <ShellContent
                ContentTemplate="{DataTemplate local:MainPage}"
                Route="MainPage" />
        </Tab>

        <Tab Title="Коллекция">
            <ShellContent
                ContentTemplate="{DataTemplate local:SavedMemesPage}"
                Route="SavedMemesPage" />
        </Tab>
    </TabBar>

</Shell>
