<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="mem1.SavedMemesPage"
             Title="Сгенерированные мемы">

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="15">
            <Label Text="Ваша коллекция" 
                   FontSize="22" 
                   FontAttributes="Bold" 
                   HorizontalOptions="Center" />

            <CollectionView x:Name="MemesCollectionView" ItemsLayout="VerticalGrid, 2">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Margin="5" Padding="5" BorderColor="LightGray" CornerRadius="8">
                            <Image Source="{Binding}" 
                                   HeightRequest="150" 
                                   Aspect="AspectFit" />
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>