<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="mem1.MainPage"
             BackgroundColor="#F0F8FF">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Label Text="Генератор Мемов" 
                   FontSize="28"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="#2C3E50" />

            <Border StrokeShape="RoundRectangle 20"
                    StrokeThickness="0"
                    BackgroundColor="White"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    Margin="10">
                <Border.Shadow>
                    <Shadow Brush="Gray" Offset="0,10" Radius="15" Opacity="0.3" />
                </Border.Shadow>

                <Image x:Name="MemImage"
                       Source="memea.gif"
                       HeightRequest="300"
                       WidthRequest="300"
                       Aspect="AspectFit" />
            </Border>

            <Label x:Name="CountLabel" 
                   Text="Сгенерировано мемов: 0" 
                   HorizontalOptions="Center" 
                   FontSize="18"
                   TextColor="#7F8C8D" />

            <VerticalStackLayout Spacing="15">
                <Button x:Name="CounterBtn" 
                        Text="Генерировать мем" 
                        FontSize="16"
                        BackgroundColor="#3498DB"
                        TextColor="White"
                        CornerRadius="25"
                        HeightRequest="50"
                        Clicked="OnCounterClicked" />

                <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                    <Button Text="В избранное" 
                            BackgroundColor="gray"
                            TextColor="White"
                            CornerRadius="20"
                            Clicked="OnFavoriteClicked" />
                </HorizontalStackLayout>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>